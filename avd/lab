#!/usr/bin/env bash
# declaw-env lab: one command to a rooted Android that decrypts an app's HTTPS into Burp.
#
# Backend is the optional first arg (default qemu):
#   qemu  REAL aarch64 Android 16 (qemu TCG, rooted). The ONLY backend that runs
#         declaw's arm64-only primitives (mempatch, HWBP). Slower.
#   avd   x86_64 Android (Google emulator, KVM, rooted). Fast; OkHttp/NSC/Flutter.
#
# Usage: lab [qemu|avd] [command | apk | package]     default: qemu, boot+root+UI+shell
#   (nothing)   boot (if needed) + root + UI window + root shell
#   APK | PKG   boot + install (if APK) + send that app's HTTPS to Burp + UI  [pentest one-liner]
#   capture [X] same as passing X: X = .apk to install, a package to scope, or nothing for
#               all apps. Decrypts to Burp (127.0.0.1:8080) and capture/traffic.log.
#   probe P L O confirm L@O is the LIVE ssl_verify_peer_cert in pkg P (BRK; you drive 1 request).
#   provision   one-time: fetch + prepare a rooted image
#   up root shell ui   the individual steps, all folded into the default
#   status | down      show state | stop (also stops the MITM)
#
# Burp: just run Burp with its default proxy listener. declaw-patched apps trust ANY
# cert, so there is NO device CA to install. Point elsewhere with BURP=host:port, or
# BURP= (empty) to skip Burp and only write the log.
set -euo pipefail
HERE="$(cd "$(dirname "$0")" && pwd)"
SDK="${ANDROID_SDK_ROOT:-$HOME/Android/sdk}"
export ANDROID_SDK_ROOT="$SDK" ANDROID_HOME="$SDK"
export PATH="$SDK/platform-tools:$SDK/emulator:$SDK/cmdline-tools/latest/bin:$PATH"
# avdmanager/emulator need a valid JDK; the shell's JAVA_HOME is often stale.
if [ ! -x "${JAVA_HOME:-/nonexistent}/bin/java" ]; then
  for j in java-17-openjdk java-21-openjdk java-17 default; do
    [ -x "/usr/lib/jvm/$j/bin/java" ] && { export JAVA_HOME="/usr/lib/jvm/$j"; break; }
  done
fi

usage() { sed -n '2,21p' "$0" | sed 's/^# \{0,1\}//'; exit "${1:-0}"; }
case "${1:-}" in -h|--help|help) usage 0 ;; esac
# Backend is an optional first arg. Then a known subcommand runs as-is; anything else
# (a bare apk/dir/package, or nothing) means the default `go`, which captures that target.
BACKEND=qemu
case "${1:-}" in qemu|avd) BACKEND="$1"; shift ;; esac
case "${1:-}" in
  go|provision|up|root|shell|ui|capture|probe|status|down) CMD="$1"; shift ;;
  *) CMD=go ;;   # empty or a bare apk/pkg -> go [target]
esac

# ---------------------------------------------------------------- qemu (arm64)
QPORT=6555; QDEV="localhost:$QPORT"; QRUN="$HOME/Android/lineage-arm64/run"
qemu_up() {
  pgrep -f 'qemu-system-aarch64.*declaw-lineage' >/dev/null && { echo "[qemu] already up"; return; }
  [ -f "$HOME/Android/lineage-arm64/vda.raw" ] || { echo "[qemu] run 'lab qemu provision' first"; exit 1; }
  nohup "$HERE/boot-arm64.sh" >/tmp/declaw-qemu.log 2>&1 &
  echo "[qemu] booting (headless, ~4 min first time). tail /tmp/declaw-qemu.log"
}
qemu_down() {
  mitm_stop
  local mon="$QRUN/mon.sock"
  [ -S "$mon" ] && echo quit | socat - "UNIX-CONNECT:$mon" >/dev/null 2>&1 || true
  sleep 2; pgrep -f 'qemu-system-aarch64.*declaw-lineage' >/dev/null && echo "[qemu] still up" || echo "[qemu] down (MITM stopped, guest redirect gone with the VM)"
}
qemu_status() {
  pgrep -f 'qemu-system-aarch64.*declaw-lineage' >/dev/null && echo "[qemu] running" || { echo "[qemu] stopped"; return; }
  adb connect "$QDEV" >/dev/null 2>&1
  adb -s "$QDEV" shell 'echo up: uid=$(id -u) $(getprop ro.build.version.release) $(uname -m) selinux=$(getenforce)' 2>/dev/null | tr -d '\r'
}
qemu_ensure() {  # boot (if needed) + wait + root; returns with the device up and rooted
  [ -f "$HOME/Android/lineage-arm64/vda.raw" ] || { echo "[qemu] run 'lab qemu provision' first"; exit 1; }
  qemu_up; echo "[qemu] waiting for boot (first cold boot ~4 min)..."
  adb connect "$QDEV" >/dev/null 2>&1 || true
  for _ in $(seq 1 90); do
    [ "$(timeout 6 adb -s "$QDEV" shell getprop sys.boot_completed 2>/dev/null | tr -d '\r')" = 1 ] && break
    pgrep -f 'qemu-system-aarch64.*declaw-lineage' >/dev/null || { echo "[qemu] boot failed, see /tmp/declaw-qemu.log"; exit 1; }
    sleep 8; adb connect "$QDEV" >/dev/null 2>&1 || true
  done
  "$HERE/adb-root.sh" >/dev/null 2>&1 || echo "[qemu] warning: root not confirmed"
}
qemu_go() {  # $1 optional capture target (apk / split dir / package)
  qemu_ensure
  ui "$QDEV" qemu
  if [ -n "${1:-}" ]; then
    do_capture "$QDEV" "$1"          # install/redirect to Burp, then follows the log (blocks)
  else
    echo "[qemu] root shell. device + window stay up on exit ('lab qemu down' to stop)."
    exec adb -s "$QDEV" shell
  fi
}

# ---------------------------------------------------------------- avd (x86_64)
AVD_NAME=declaw_x86_64; AVD_IMG="system-images;android-33;google_apis;x86_64"
avd_provision() { ABI=x86_64 "$HERE/setup.sh"; echo "no" | avdmanager create avd -n "$AVD_NAME" -k "$AVD_IMG" -d pixel_6 --force >/dev/null; echo "[avd] ready ($AVD_NAME)"; }
avd_running() { pgrep -f -- "-avd $AVD_NAME" >/dev/null; }
# adb -e/-d are unreliable when TCP devices (the qemu rig) are also connected, so
# target the real emulator-<port> serial explicitly.
avd_serial() { adb devices | awk '/^emulator-/{print $1; exit}'; }
avd_up() {
  avd_running && { echo "[avd] already up"; return; }
  emulator -list-avds 2>/dev/null | grep -qx "$AVD_NAME" || { echo "[avd] run 'lab avd provision' first"; exit 1; }
  nohup emulator -avd "$AVD_NAME" -no-window -no-audio -no-boot-anim -no-snapshot \
    -writable-system -gpu swiftshader_indirect -no-metrics >/tmp/declaw-avd.log 2>&1 &
  echo "[avd] booting (KVM). tail /tmp/declaw-avd.log"
}
avd_root() {
  local S; S="$(avd_serial)"; [ -n "$S" ] || { echo "[avd] not up"; exit 1; }
  adb -s "$S" root >/dev/null 2>&1; sleep 2; adb -s "$S" wait-for-device
  adb -s "$S" remount >/dev/null 2>&1 || { adb -s "$S" disable-verity >/dev/null 2>&1; adb -s "$S" reboot; adb -s "$S" wait-for-device; adb -s "$S" root >/dev/null 2>&1; sleep 2; adb -s "$S" remount >/dev/null 2>&1; }
  adb -s "$S" shell id 2>&1 | tr -d '\r'
}
avd_down() { mitm_stop; local S; S="$(avd_serial)"; [ -n "$S" ] && adb -s "$S" emu kill >/dev/null 2>&1 || true; echo "[avd] stopped"; }
avd_status() {
  local S; S="$(avd_serial)"; [ -n "$S" ] || { echo "[avd] no emulator"; return; }
  adb -s "$S" shell 'echo up: uid=$(id -u) $(getprop ro.build.version.release) $(getprop ro.product.cpu.abi) selinux=$(getenforce)' 2>/dev/null | tr -d '\r'
}
avd_ensure() {  # boot (if needed) + wait + root; returns with the device up and rooted
  emulator -list-avds 2>/dev/null | grep -qx "$AVD_NAME" || { echo "[avd] run 'lab avd provision' first"; exit 1; }
  avd_up; local S; echo "[avd] waiting for boot..."
  for _ in $(seq 1 50); do
    S="$(avd_serial)"; [ -n "$S" ] && [ "$(timeout 6 adb -s "$S" shell getprop sys.boot_completed 2>/dev/null | tr -d '\r')" = 1 ] && break
    pgrep -f 'qemu-system-x86_64' >/dev/null || { echo "[avd] boot failed, see /tmp/declaw-avd.log"; exit 1; }
    sleep 6
  done
  avd_root >/dev/null 2>&1 || echo "[avd] warning: root not confirmed"
}
avd_go() {  # $1 optional capture target (apk / split dir / package)
  avd_ensure
  local S; S="$(avd_serial)"
  ui "$S" avd
  if [ -n "${1:-}" ]; then
    do_capture "$S" "$1"
  else
    echo "[avd] root shell. device + window stay up on exit ('lab avd down' to stop)."
    exec adb -s "$S" shell
  fi
}

# ---------------------------------------------------------------- UI (scrcpy)
# scrcpy mirrors + controls any adb device, so one UI works for both backends
# regardless of the qemu display being headless (it captures Android display 0).
SCRCPY_VER=v4.0
SCRCPY_DIR="$HERE/../bin/scrcpy-linux-x86_64-${SCRCPY_VER}"
SCRCPY_URL="https://github.com/Genymobile/scrcpy/releases/download/${SCRCPY_VER}/scrcpy-linux-x86_64-${SCRCPY_VER}.tar.gz"
resolve_scrcpy() {
  type -P scrcpy 2>/dev/null && return
  [ -x "$SCRCPY_DIR/scrcpy" ] && { echo "$SCRCPY_DIR/scrcpy"; return; }
  [ "$(uname -m)" = x86_64 ] || { echo "[ui] install scrcpy (bundled prebuilt is x86_64 only)" >&2; return 1; }
  mkdir -p "$HERE/../bin"; curl -fsSL "$SCRCPY_URL" -o "$HERE/../bin/scrcpy.tgz" \
    && tar xzf "$HERE/../bin/scrcpy.tgz" -C "$HERE/../bin" && rm -f "$HERE/../bin/scrcpy.tgz"
  echo "$SCRCPY_DIR/scrcpy"
}
ui() {  # $1 serial  $2 label
  local s; s="$(resolve_scrcpy)" || exit 1
  ADB="$(type -P adb)" nohup "$s" -s "$1" --no-audio --window-title="declaw-$2" \
    --max-size=1024 >/tmp/declaw-scrcpy-$2.log 2>&1 &
  echo "[ui] scrcpy pid $! -> declaw-$2 window (log /tmp/declaw-scrcpy-$2.log)"
}

# --------------------------------------------------- install + capture (both)
# Both backends are on qemu user-net, so the host is 10.0.2.2 from the guest, and
# both are rooted. A declaw-patched (or mempatched) app accepts any cert, so a
# throwaway-cert host MITM terminates its TLS and reads the plaintext. We uid-scope
# an iptables DNAT of that app's 443 to the host MITM. Decrypted flows go to Burp
# (127.0.0.1:8080) if up, and always to capture/traffic.log.
GW=10.0.2.2; MITMP="${MITM_PORT:-8083}"
BURP="${BURP-127.0.0.1:8080}"        # default listener; BURP= (empty) skips Burp, log only
TRAFFIC_LOG_FILE="$HERE/../capture/traffic.log"
mitm_start() {
  # reuse only if something already listens on OUR port; a mitm on a different port
  # must not make us skip (the DNAT points at $MITMP).
  (exec 3<>"/dev/tcp/127.0.0.1/$MITMP") 2>/dev/null && { exec 3>&-; return; }
  command -v python3 >/dev/null || { echo "[mitm] need python3"; exit 1; }
  mkdir -p "$(dirname "$TRAFFIC_LOG_FILE")"
  MITM_BIND=0.0.0.0 MITM_PORT="$MITMP" TRAFFIC_LOG="$TRAFFIC_LOG_FILE" BURP="$BURP" \
    nohup python3 "$HERE/mitm/mitm_fwd.py" >/tmp/declaw-mitm.log 2>&1 &
  sleep 1
}
# Tell the pentester exactly where their decrypted traffic goes. The whole point of
# declaw is that the app trusts ANY cert, so Burp needs only its default proxy listener
# and there is never a device CA to install.
burp_status() {
  [ -n "$BURP" ] || { echo "[burp] off (BURP empty): flows decrypt to the log only"; return; }
  local bh="${BURP%:*}" bp="${BURP##*:}"
  if (exec 3<>"/dev/tcp/$bh/$bp") 2>/dev/null; then exec 3>&-
    echo "[burp] connected $BURP: decrypted requests land in Burp's HTTP history. No device CA needed."
  else
    echo "[burp] $BURP not reachable. Start Burp (Proxy > default listener 127.0.0.1:8080) and re-run;"
    echo "[burp] until then flows still decrypt to the log. A device CA is never needed (app trusts any cert)."
  fi
}
app_uid() { adb -s "$1" shell "pm list packages -U $2" 2>/dev/null | tr -d '\r' | sed -n 's/.*uid://p' | head -1; }
# Self-check: is the redirect actually yielding plaintext? A decrypted request logs as REQ;
# a rejected cert logs as TLS_FAIL. Only TLS_FAIL means the app is not declaw-patched here,
# OR it is cronet/HTTP3 (QUIC over UDP, which a MITM cannot see -> use friTap keylog instead).
capture_verify() {  # $1 serial(unused)  $2 pkg-or-empty
  local pkg="${2:-}" base req=0 fail=0
  base=$(wc -l < "$TRAFFIC_LOG_FILE" 2>/dev/null || echo 0)
  echo "[verify] watching ~10s. Drive the app in the UI window (a relaunch here would reset it)..."
  for _ in $(seq 1 5); do
    sleep 2
    req=$(tail -n +"$((base + 1))" "$TRAFFIC_LOG_FILE" 2>/dev/null | grep -c '] REQ ' || true)
    if [ "${req:-0}" -gt 0 ]; then break; fi
  done
  fail=$(tail -n +"$((base + 1))" "$TRAFFIC_LOG_FILE" 2>/dev/null | grep -c 'TLS_FAIL' || true)
  if [ "${req:-0}" -gt 0 ]; then
    echo "[verify] OK: decrypting ($req plaintext request(s)). The bypass works."
  elif [ "${fail:-0}" -gt 0 ]; then
    echo "[verify] cert REJECTED ($fail TLS_FAIL): the app is not declaw-patched here, OR it is"
    echo "[verify] cronet/HTTP3 (QUIC over UDP, invisible to a MITM). For QUIC use keylog:"
    echo "[verify]   declaw ${pkg:-<pkg>} --capture   (friTap SSLKEYLOG + pcap, decrypt in Wireshark)"
  else
    echo "[verify] no app TLS seen yet; drive the app in the UI window and watch below."
  fi
}
# capture [apk|pkg]: the one decrypt command. With an .apk (or split dir) it installs it
# first; with a package it scopes to that app; with nothing it redirects all HTTPS. Then
# it points the app's 443 at the host MITM and follows the decrypted log (Ctrl-C to stop
# watching; the redirect stays until `down`). Decrypted flows also go to Burp if it is up.
do_capture() {
  adb connect "$1" >/dev/null 2>&1
  adb -s "$1" shell id -u 2>/dev/null | grep -q '^0' || { echo "[capture] need root (lab $BACKEND root)"; exit 1; }
  adb -s "$1" shell "iptables -t nat -L OUTPUT -n" >/dev/null 2>&1 || { echo "[capture] guest has no nat table"; exit 1; }
  local arg="${2:-}" own="" who="all apps" vpkg=""
  if [ -n "$arg" ] && [ -e "$arg" ]; then
    echo "[capture] installing $arg"
    if [ -d "$arg" ]; then adb -s "$1" install-multiple -r "$arg"/*.apk; else adb -s "$1" install -r "$arg"; fi
    arg=""
  fi
  if [ -n "$arg" ]; then local uid; uid="$(app_uid "$1" "$arg")"; [ -n "$uid" ] || { echo "[capture] $arg not installed"; exit 1; }; own="-m owner --uid-owner $uid"; who="$arg (uid $uid)"; vpkg="$arg"; fi
  mitm_start
  adb -s "$1" shell "
    sysctl -w net.ipv4.conf.all.route_localnet=1 >/dev/null 2>&1
    iptables -t nat -D OUTPUT -p tcp --dport 443 $own -j DNAT --to-destination $GW:$MITMP 2>/dev/null
    iptables -t nat -A OUTPUT -p tcp --dport 443 $own -j DNAT --to-destination $GW:$MITMP
    iptables -t nat -C POSTROUTING -p tcp -d $GW --dport $MITMP -j MASQUERADE 2>/dev/null || iptables -t nat -A POSTROUTING -p tcp -d $GW --dport $MITMP -j MASQUERADE
  "
  burp_status
  capture_verify "$1" "$vpkg"
  echo "[capture] $who HTTPS -> host MITM (:$MITMP). Following the plaintext log (Ctrl-C stops watching; the redirect stays until 'lab $BACKEND down'):"
  exec tail -n +1 -f "$TRAFFIC_LOG_FILE"
}
mitm_stop() { pkill -f 'avd/mitm/mitm_fwd.py' 2>/dev/null || true; }

# ---------------------------------------------------------------- BRK-probe
# BoringSSL ships ssl_verify_peer_cert (patch this) and a near-identical
# ssl_reverify_peer_cert decoy (patching it is a silent no-op). `declaw find_verify`
# picks the live one statically; this confirms it dynamically. It writes a BRK #0 at
# lib@offset; if the app takes SIGTRAP there while you drive one request, that offset
# is on the live handshake path.
mempoke_stage() {  # $1=dev ; build (once) + push the peek/poke helper
  local dev="$1" bin="$HERE/bin/mempoke-arm64"
  if [ ! -x "$bin" ]; then
    command -v aarch64-linux-gnu-gcc >/dev/null || { echo "[probe] need aarch64-linux-gnu-gcc to build mempoke" >&2; return 1; }
    mkdir -p "$HERE/bin"
    aarch64-linux-gnu-gcc -O2 -static -no-pie -o "$bin" "$HERE/mempoke.c" || return 1
  fi
  adb -s "$dev" push "$bin" /data/local/tmp/mempoke >/dev/null && adb -s "$dev" shell chmod 755 /data/local/tmp/mempoke
}
do_probe() {  # $1=dev $2=pkg $3=lib-substr $4=hex-offset
  local dev="$1" pkg="${2:-}" lib="${3:-}" off="${4:-}"
  { [ -n "$pkg" ] && [ -n "$lib" ] && [ -n "$off" ]; } || { echo "usage: lab <backend> probe <pkg> <lib-substr> <hex-offset>"; exit 1; }
  adb connect "$dev" >/dev/null 2>&1 || true
  mempoke_stage "$dev" || exit 1
  local pid; pid="$(adb -s "$dev" shell pidof "$pkg" 2>/dev/null | tr -d '\r' || true)"
  [ -n "$pid" ] || { echo "[probe] $pkg not running; launch it first"; exit 1; }
  local res addr before
  res="$(adb -s "$dev" shell /data/local/tmp/mempoke "$pid" "$lib" "$off" = 000020d4 2>&1 | tr -d '\r' || true)"
  addr="$(printf '%s' "$res" | sed -n 's/.*addr=\(0x[0-9a-f]*\).*/\1/p')"
  before="$(printf '%s' "$res" | sed -n 's/.*before=\([0-9a-f]\{8\}\).*/\1/p')"
  [ -n "$addr" ] || { echo "[probe] could not arm BRK: $res"; exit 1; }
  adb -s "$dev" shell logcat -c >/dev/null 2>&1 || true
  echo "[probe] BRK armed at $lib@$off ($addr) in pid $pid. Exercise the app's TLS now; watching 40s..."
  local hit=""
  for _ in $(seq 1 20); do
    if adb -s "$dev" shell logcat -d -t 400 2>/dev/null | grep -q "SIGTRAP.*$addr"; then hit=1; break; fi
    sleep 2
  done
  if [ -n "$hit" ]; then
    echo "[probe] HIT: $lib@$off IS on the live handshake path. Patch it: declaw --mode mempatch --offset $lib@$off"
    echo "[probe] (the app took the SIGTRAP and died; relaunch it.)"
  else
    echo "[probe] miss: $lib@$off was NOT executed in 40s. Likely the ssl_reverify_peer_cert decoy or a wrong offset."
    echo "[probe] get the live offset with: python -m declaw.find_verify <lib.so>"
    if [ -n "$before" ]; then
      adb -s "$dev" shell /data/local/tmp/mempoke "$pid" "$lib" "$off" = "$before" >/dev/null 2>&1 || true
      echo "[probe] restored original bytes at $addr."
    fi
  fi
}

case "$BACKEND:$CMD" in
  qemu:go)        qemu_go "${1:-}" ;;
  qemu:capture)   qemu_ensure; do_capture "$QDEV" "${1:-}" ;;
  qemu:probe)     do_probe "$QDEV" "$@" ;;
  qemu:provision) "$HERE/provision.sh" ;;
  qemu:up)        qemu_up ;;
  qemu:root)      "$HERE/adb-root.sh" ;;
  qemu:shell)     adb connect "$QDEV" >/dev/null 2>&1; exec adb -s "$QDEV" shell "$@" ;;
  qemu:ui)        adb connect "$QDEV" >/dev/null 2>&1; ui "$QDEV" qemu ;;
  qemu:status)    qemu_status ;;
  qemu:down)      qemu_down ;;
  avd:go)         avd_go "${1:-}" ;;
  avd:capture)    avd_ensure; do_capture "$(avd_serial)" "${1:-}" ;;
  avd:probe)      do_probe "$(avd_serial)" "$@" ;;
  avd:provision)  avd_provision ;;
  avd:up)         avd_up ;;
  avd:root)       avd_root ;;
  avd:shell)      exec adb -s "$(avd_serial)" shell "$@" ;;
  avd:ui)         ui "$(avd_serial)" avd ;;
  avd:status)     avd_status ;;
  avd:down)       avd_down ;;
  *) echo "unknown: $BACKEND $CMD"; usage 1 ;;
esac
