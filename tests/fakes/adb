#!/usr/bin/env bash
set -u

profile=${FAKE_ADB_PROFILE:-multilib}

if [[ ${1:-} != "-s" || -z ${2:-} ]]; then
  echo "fake adb: every call must select a serial with -s" >&2
  exit 96
fi
serial=$2
shift 2

if [[ -n ${FAKE_ADB_LOG:-} ]]; then
  printf '%s\n' "-s $serial $*" >>"$FAKE_ADB_LOG"
fi

if [[ -n ${FAKE_ADB_ARGV_LOG:-} ]]; then
  {
    printf '%q ' -s "$serial"
    printf '%q ' "$@"
    printf '\n'
  } >>"$FAKE_ADB_ARGV_LOG"
fi

if [[ $profile == unreachable ]]; then
  echo "error: device '$serial' not found" >&2
  exit 1
fi

if [[ $profile == hang && ${1:-} != get-state ]]; then
  sleep 5
fi

command=${1:-}
remote=
if [[ $command == shell ]]; then
  shift
  remote="$*"
  if [[ $remote == "getprop ro.build.version.release" && $profile == collection-failure ]]; then
    exit 42
  fi
fi

case "$command" in
  install|install-multiple)
    shift
    abi=
    [[ ${1:-} == -r ]] || {
      echo "fake adb: installer omitted -r" >&2
      exit 94
    }
    shift
    if [[ ${1:-} == --abi ]]; then
      [[ -n ${2:-} ]] || {
        echo "fake adb: --abi omitted its value" >&2
        exit 94
      }
      abi=$2
      shift 2
    fi
    (($# > 0)) || {
      echo "fake adb: installer passed no APKs" >&2
      exit 94
    }
    if [[ -n ${FAKE_ADB_INSTALL_LOG:-} ]]; then
      {
        printf '%s' "$command"
        for apk in "$@"; do
          printf '\t%s' "$(basename "$apk")"
        done
        printf '\n'
      } >>"$FAKE_ADB_INSTALL_LOG"
    fi
    for apk in "$@"; do
      [[ -f $apk && $apk == *.apk ]] || {
        echo "fake adb: invalid APK argument: $apk" >&2
        exit 93
      }
    done
    if [[ ${FAKE_ADB_FAIL_INSTALL:-0} == abis ]]; then
      echo "Failure [INSTALL_FAILED_NO_MATCHING_ABIS]" >&2
      exit 1
    fi
    if [[ ${FAKE_ADB_FAIL_INSTALL:-0} == 1 ]]; then
      echo "Failure [INSTALL_FAILED_TEST]" >&2
      exit 42
    fi
    if [[ -n ${FAKE_ACCEPT_INSTALLED_ROOT:-} ]]; then
      package=
      case "$abi" in
        arm64-v8a) package=com.twitter.android ;;
        armeabi-v7a) package=com.instagram.android ;;
      esac
      if [[ -n $package && ${FAKE_ACCEPT_SKIP_INSTALL_COPY:-} != "$package" ]]; then
        mkdir -p "$FAKE_ACCEPT_INSTALLED_ROOT/$package"
        for apk in "$@"; do
          cp -- "$apk" "$FAKE_ACCEPT_INSTALLED_ROOT/$package/$(basename "$apk")"
        done
      fi
    fi
    echo Success
    ;;
  pull)
    shift
    remote_path=${1:-}
    local_path=${2:-}
    [[ -n $remote_path && -n $local_path && -n ${FAKE_ACCEPT_INSTALLED_ROOT:-} ]] || {
      echo "fake adb: invalid pull arguments" >&2
      exit 94
    }
    package=
    case "$remote_path" in
      *com.twitter.android*) package=com.twitter.android ;;
      *com.instagram.android*) package=com.instagram.android ;;
    esac
    basename=${remote_path##*/}
    [[ -n $package && -f $FAKE_ACCEPT_INSTALLED_ROOT/$package/$basename ]] || {
      echo "fake adb: installed file not found for pull: $remote_path" >&2
      exit 93
    }
    mkdir -p -- "$(dirname "$local_path")"
    cp -- "$FAKE_ACCEPT_INSTALLED_ROOT/$package/$basename" "$local_path"
    ;;
  get-state)
    echo device
    ;;
  shell)
    path=
    case "$remote" in
      sh\ -c\ *)
        echo "sh: syntax error: serialized sh -c arguments lost quoting" >&2
        exit 2
        ;;
      getprop\ *)
        key=${remote#getprop }
        case "$key" in
          ro.build.version.release) echo 16 ;;
          ro.build.version.sdk) echo 36 ;;
          ro.product.cpu.abi)
            if [[ $profile == avd ]]; then echo x86_64; else echo arm64-v8a; fi
            ;;
          ro.zygote)
            if [[ $profile == arm64only ]]; then echo zygote64; else echo zygote64_32; fi
            ;;
          ro.product.cpu.abilist64) echo arm64-v8a ;;
          ro.product.cpu.abilist32)
            if [[ $profile == arm64only ]]; then echo; else echo armeabi-v7a,armeabi; fi
            ;;
          *) exit 95 ;;
        esac
        ;;
      "uname -m") echo aarch64 ;;
      "id -u") echo 0 ;;
      getenforce) echo Permissive ;;
      "cat /proc/sys/kernel/random/boot_id")
        if [[ $profile != accept ]]; then
          echo "fake adb: boot_id is only available in the accept profile" >&2
          exit 95
        fi
        calls_file=${FAKE_ACCEPT_BOOT_CALLS_FILE:-}
        calls=0
        if [[ -n $calls_file && -f $calls_file ]]; then
          read -r calls <"$calls_file"
        fi
        ((calls += 1))
        if [[ -n $calls_file ]]; then
          printf '%s\n' "$calls" >"$calls_file"
        fi
        if [[ ${FAKE_ACCEPT_CHANGE_BOOT_AFTER:-999} -lt $calls ]]; then
          echo 22222222-2222-2222-2222-222222222222
        else
          echo 11111111-1111-1111-1111-111111111111
        fi
        ;;
      "dumpsys package com.twitter.android")
        [[ $profile == accept ]] || exit 95
        printf '  versionCode=%s minSdk=24 targetSdk=36\n' \
          "${FAKE_ACCEPT_X_VERSION:-312020200}"
        printf '  primaryCpuAbi=%s\n' "${FAKE_ACCEPT_X_ABI:-arm64-v8a}"
        ;;
      "dumpsys package com.instagram.android")
        [[ $profile == accept ]] || exit 95
        printf '  versionCode=%s minSdk=24 targetSdk=36\n' \
          "${FAKE_ACCEPT_INSTAGRAM_VERSION:-383611189}"
        printf '  primaryCpuAbi=%s\n' \
          "${FAKE_ACCEPT_INSTAGRAM_ABI:-armeabi-v7a}"
        ;;
      "pm path com.twitter.android")
        [[ $profile == accept ]] || exit 95
        IFS=, read -r -a splits <<< \
          "${FAKE_ACCEPT_X_SPLITS:-base.apk,split_config.arm64_v8a.apk,split_config.en.apk}"
        for split in "${splits[@]}"; do
          printf 'package:/data/app/com.twitter.android/%s\n' "$split"
        done
        ;;
      "pm path com.instagram.android")
        [[ $profile == accept ]] || exit 95
        IFS=, read -r -a splits <<< \
          "${FAKE_ACCEPT_INSTAGRAM_SPLITS:-base.apk,split_config.en.apk}"
        for split in "${splits[@]}"; do
          printf 'package:/data/app/com.instagram.android/%s\n' "$split"
        done
        ;;
      "cmd package resolve-activity --brief --components --user 0 -a android.intent.action.MAIN -c android.intent.category.LAUNCHER -p com.twitter.android")
        [[ $profile == accept ]] || exit 95
        echo "${FAKE_ACCEPT_X_COMPONENT:-com.twitter.android/.StartActivity}"
        ;;
      "cmd package resolve-activity --brief --components --user 0 -a android.intent.action.MAIN -c android.intent.category.LAUNCHER -p com.instagram.android")
        [[ $profile == accept ]] || exit 95
        echo "${FAKE_ACCEPT_INSTAGRAM_COMPONENT:-com.instagram.android/.MainActivity}"
        ;;
      "am force-stop com.twitter.android"|"am force-stop com.instagram.android")
        [[ $profile == accept ]] || exit 95
        ;;
      "am start -W -n com.twitter.android/.StartActivity"|\
      "am start -W -n com.instagram.android/.MainActivity")
        [[ $profile == accept ]] || exit 95
        echo "Status: ok"
        ;;
      "logcat -c")
        [[ $profile == accept ]] || exit 95
        ;;
      "logcat -d -v brief")
        [[ $profile == accept ]] || exit 95
        printf '%s\n' "${FAKE_ACCEPT_LOGCAT:-I/ActivityTaskManager: Displayed activity}"
        ;;
      "pidof com.twitter.android")
        [[ $profile == accept ]] || exit 95
        [[ ${FAKE_ACCEPT_MISSING_PID:-} != com.twitter.android ]] && echo 6401
        ;;
      "pidof com.instagram.android")
        [[ $profile == accept ]] || exit 95
        [[ ${FAKE_ACCEPT_MISSING_PID:-} != com.instagram.android ]] && echo 3201
        ;;
      "readlink /proc/6401/exe")
        [[ $profile == accept ]] || exit 95
        echo "${FAKE_ACCEPT_X_EXE:-/system/bin/app_process64}"
        ;;
      "readlink /proc/3201/exe")
        [[ $profile == accept ]] || exit 95
        echo "${FAKE_ACCEPT_INSTAGRAM_EXE:-/system/bin/app_process32}"
        ;;
      *CONFIG_COMPAT*)
        case $profile in
          disabled-config) echo "# CONFIG_COMPAT is not set" ;;
          unreadable-config|unreadable-no-probe) echo "<unreadable>" ;;
          *) echo CONFIG_COMPAT=y ;;
        esac
        ;;
      *linker\ --help*)
        if [[ $profile == unreadable-no-probe ]]; then
          echo status=1
        else
          echo status=0
        fi
        ;;
      "if [ -x '/system/bin/app_process64' ]; then echo executable; else echo missing; fi")
        path=/system/bin/app_process64
        ;;
      "if [ -x '/apex/com.android.runtime/bin/linker64' ]; then echo executable; else echo missing; fi")
        path=/apex/com.android.runtime/bin/linker64
        ;;
      "if [ -x '/system/bin/app_process32' ]; then echo executable; else echo missing; fi")
        path=/system/bin/app_process32
        ;;
      "if [ -x '/apex/com.android.runtime/bin/linker' ]; then echo executable; else echo missing; fi")
        path=/apex/com.android.runtime/bin/linker
        ;;
      *)
        echo "fake adb: unsupported serialized shell command: $remote" >&2
        exit 95
        ;;
    esac
    if [[ -n $path ]]; then
      case "$profile:$path" in
        multilib:/system/bin/app_process64|multilib:/apex/com.android.runtime/bin/linker64|multilib:/system/bin/app_process32|multilib:/apex/com.android.runtime/bin/linker|accept:/system/bin/app_process64|accept:/apex/com.android.runtime/bin/linker64|accept:/system/bin/app_process32|accept:/apex/com.android.runtime/bin/linker|disabled-config:/system/bin/app_process64|disabled-config:/apex/com.android.runtime/bin/linker64|disabled-config:/system/bin/app_process32|disabled-config:/apex/com.android.runtime/bin/linker|unreadable-config:/system/bin/app_process64|unreadable-config:/apex/com.android.runtime/bin/linker64|unreadable-config:/system/bin/app_process32|unreadable-config:/apex/com.android.runtime/bin/linker|unreadable-no-probe:/system/bin/app_process64|unreadable-no-probe:/apex/com.android.runtime/bin/linker64|unreadable-no-probe:/system/bin/app_process32|unreadable-no-probe:/apex/com.android.runtime/bin/linker)
          echo executable
          ;;
        arm64only:/system/bin/app_process64|arm64only:/apex/com.android.runtime/bin/linker64)
          echo executable
          ;;
        *) echo missing ;;
      esac
    fi
    ;;
  *)
    echo "fake adb: unsupported call: $*" >&2
    exit 95
    ;;
esac
